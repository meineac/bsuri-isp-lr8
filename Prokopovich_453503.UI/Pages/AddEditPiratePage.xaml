<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Prokopovich_453503.UI.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="models:AddEditPirateViewModel"
             x:Class="Prokopovich_453503.UI.Pages.AddEditPiratePage"
             x:Name="Page"
             Title="{Binding PageTitle}">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding Source={x:Reference Page}, Path=BindingContext}"
            EventName="Loaded"
            Command="{Binding LoadCrewsCommand}"/>
    </ContentPage.Behaviors>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Имя" FontAttributes="Bold"/>
            <Entry Text="{Binding Name}" Placeholder="Имя пирата"/>

            <Label Text="Bounty (Berry)" FontAttributes="Bold"/>
            <Entry Text="{Binding BountyText}"
                   Placeholder="0"
                   Keyboard="Numeric"/>

            <Label Text="Роль" FontAttributes="Bold"/>
            <Entry Text="{Binding Role}" Placeholder="Captain, Swordsman..."/>

            <Label Text="Способности (через запятую)" FontAttributes="Bold"/>
            <Entry Text="{Binding AbilitiesText}" Placeholder="Gomu Gomu no Mi, Haki"/>

            <Label Text="Команда" FontAttributes="Bold"/>
            <Picker ItemsSource="{Binding AllCrews}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedCrew, Mode=TwoWay}"
                    Title="Выберите команду"/>

            <Button Text="Сохранить"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#5E35B1"
                    TextColor="White"
                    CornerRadius="8"
                    Margin="0,10,0,0"/>

            <Button Text="Отмена"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="Gray"
                    TextColor="White"
                    CornerRadius="8"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>